# ─────────────────────────────────────────────────────────────
# NetGuard Environment Variables
# Copy this file to .env and edit the values
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Slack/Teams/Discord webhook URL for n8n alerts
# Get yours from: https://api.slack.com/messaging/webhooks
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Monitoring thresholds (Workflow 1)
ANOMALY_RATE_THRESHOLD=15
RISK_SCORE_THRESHOLD=0.6
CRITICAL_COUNT_THRESHOLD=5

# Live monitoring (Workflow 5)
NETGUARD_AUTO_RESTART=true
NETGUARD_EXPECT_RUNNING=false
NETGUARD_DEFAULT_INTERFACE=lo

# ─────────────────────────────────────────────────────────────
# OSINT / Threat Intelligence
# ─────────────────────────────────────────────────────────────
# Set these in your environment (or copy to .env) to enable OSINT validation.
OSINT_ENABLED=true
OSINT_CACHE_TTL_SECONDS=3600
OSINT_MAX_RETRIES=2
OSINT_SKIP_NON_PUBLIC_IPS=true

# API Keys (do not commit real keys)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
